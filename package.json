{
  "name": "guitar-autostomp-win",
  "version": "1.0.0",
  "description": "Guitar tone switching app — switch tones at the right moment (Windows Edition)",
  "author": "AutoStomp",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "dist:backend": "cd backend && if not exist mappings mkdir mappings && pyinstaller guitar-autostomp-backend.spec && if not exist ..\\dist-backend mkdir ..\\dist-backend && xcopy /E /I /Y dist\\guitar-autostomp-backend ..\\dist-backend\\guitar-autostomp-backend",
    "dist:win": "npm run build && electron-builder --win",
    "dist": "npm run dist:backend && npm run dist:win"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.0",
    "cross-env": "^7.0.3",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wait-on": "^9.0.10",
    "zustand": "^5.0.13"
  },
  "dependencies": {
    "web-audio-beat-detector": "^8.2.36"
  }
}
